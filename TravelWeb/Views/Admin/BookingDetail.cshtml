@model TravelWeb.Models.Booking
@{
    ViewData["Title"] = "Chi tiết Booking";
    Layout = "_AdminLayout";
}

<div class="data-card">
    <h5><i class="fas fa-info-circle me-2"></i>Chi tiết đơn @Model.BookingCode</h5>

    <div class="row mt-3">
        <div class="col-md-6">
            <h6 class="text-warm" style="color: #ff7e29;">📋 Thông tin Booking</h6>
            <table class="table table-borderless">
                <tr><th width="200">Mã booking:</th><td><strong>@Model.BookingCode</strong></td></tr>
                <tr><th>Ngày đặt:</th><td>@Model.BookedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
                <tr><th>Ngày khởi hành:</th><td>@Model.DepartureDate.ToString("dd/MM/yyyy")</td></tr>
                <tr><th>Số người lớn:</th><td>@Model.NumAdults</td></tr>
                <tr><th>Số trẻ em:</th><td>@Model.NumChildren</td></tr>
                <tr><th>Trạng thái:</th><td><span class="badge-status badge-@Model.BookingStatus">@Model.BookingStatus</span></td></tr>
                <tr><th>Thanh toán:</th><td>@Model.PaymentStatus - @Model.PaymentMethod</td></tr>
                <tr><th>Yêu cầu đặc biệt:</th><td>@(Model.SpecialRequests ?? "Không có")</td></tr>
            </table>
        </div>
        <div class="col-md-6">
            <h6 class="text-warm" style="color: #ff7e29;">👤 Khách hàng</h6>
            <table class="table table-borderless">
                <tr><th width="200">Họ tên:</th><td>@Model.ContactName</td></tr>
                <tr><th>Số điện thoại:</th><td>@Model.ContactPhone</td></tr>
                <tr><th>Email:</th><td>@Model.ContactEmail</td></tr>
            </table>

            <h6 class="text-warm mt-4" style="color: #ff7e29;">🏖️ Tour đặt</h6>
            <table class="table table-borderless">
                <tr><th width="200">Tên tour:</th><td>@Model.Tour?.Name</td></tr>
                <tr><th>Điểm đến:</th><td>@Model.Tour?.Destination?.Name</td></tr>
                <tr><th>Số ngày:</th><td>@Model.Tour?.DurationDays ngày @Model.Tour?.DurationNights đêm</td></tr>
                <tr><th>Tổng tiền:</th><td><strong style="color: #ff7e29; font-size: 20px;">@Model.FinalAmount.ToString("N0")đ</strong></td></tr>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a href="/Admin/Bookings" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i> Quay lại</a>
        @if (Model.BookingStatus == "pending")
        {
            <form asp-action="UpdateBookingStatus" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.BookingId" />
                <input type="hidden" name="status" value="confirmed" />
                <button class="btn btn-success"><i class="fas fa-check me-1"></i> Xác nhận đơn</button>
            </form>
            <form asp-action="UpdateBookingStatus" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.BookingId" />
                <input type="hidden" name="status" value="cancelled" />
                <button class="btn btn-danger"><i class="fas fa-times me-1"></i> Hủy đơn</button>
            </form>
        }
    </div>
</div>
