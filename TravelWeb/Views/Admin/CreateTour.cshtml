@model TravelWeb.Models.Tour
@{
    ViewData["Title"] = "Thêm Tour mới";
    Layout = "_AdminLayout";
    var destinations = ViewBag.Destinations as List<TravelWeb.Models.Destination>;
    var categories = ViewBag.Categories as List<TravelWeb.Models.Category>;
}

<div class="data-card">
    <h5><i class="fas fa-plus-circle me-2"></i>Thêm Tour mới</h5>
    <form asp-action="CreateTour" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Mã Tour *</label>
                <input asp-for="TourCode" class="form-control" placeholder="VD: HN-HL-3N2D" required />
            </div>
            <div class="col-md-8">
                <label class="form-label">Tên Tour *</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="col-md-6">
                <label class="form-label">Điểm đến *</label>
                <select asp-for="DestinationId" class="form-select" required>
                    <option value="">-- Chọn điểm đến --</option>
                    @foreach (var d in destinations ?? new())
                    {
                        <option value="@d.DestinationId">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Danh mục *</label>
                <select asp-for="CategoryId" class="form-select" required>
                    <option value="">-- Chọn danh mục --</option>
                    @foreach (var c in categories ?? new())
                    {
                        <option value="@c.CategoryId">@c.Icon @c.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Số ngày *</label>
                <input asp-for="DurationDays" type="number" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Số đêm</label>
                <input asp-for="DurationNights" type="number" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Khởi hành từ</label>
                <input asp-for="DepartureLocation" class="form-control" placeholder="VD: Hà Nội" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Phương tiện</label>
                <input asp-for="TransportType" class="form-control" placeholder="Máy bay/Xe khách" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Giá người lớn (VNĐ) *</label>
                <input asp-for="PriceAdult" type="number" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Giá trẻ em (VNĐ)</label>
                <input asp-for="PriceChild" type="number" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Giảm giá (%)</label>
                <input asp-for="DiscountPercent" type="number" class="form-control" step="0.01" />
            </div>

            <div class="col-md-12">
                <label class="form-label">🖼️ Ảnh đại diện tour</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <small class="text-muted">Chọn file ảnh (jpg/png/gif/webp). Khuyến nghị: 800x500px</small>
            </div>

            <div class="col-md-12">
                <label class="form-label">Mô tả ngắn</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-12">
                <label class="form-label">Bao gồm</label>
                <textarea asp-for="Includes" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-12">
                <label class="form-label">Không bao gồm</label>
                <textarea asp-for="Excludes" class="form-control" rows="2"></textarea>
            </div>

            <div class="col-md-12">
                <div class="form-check">
                    <input asp-for="IsFeatured" type="checkbox" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label">Tour nổi bật (hiển thị trang chủ)</label>
                </div>
            </div>

            <div class="col-12">
                <a href="/Admin/Tours" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn-admin"><i class="fas fa-save me-1"></i> Lưu Tour</button>
            </div>
        </div>
    </form>
</div>
