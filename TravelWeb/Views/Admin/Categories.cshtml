@model List<TravelWeb.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}

<div class="data-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fas fa-tags me-2"></i>Danh mục Tour (@Model.Count)</h5>
        <a href="/Admin/CreateCategory" class="btn-admin"><i class="fas fa-plus me-1"></i> Thêm danh mục</a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Icon</th>
                <th>Tên danh mục</th>
                <th>Slug</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.CategoryId</td>
                    <td style="font-size:30px;">@c.Icon</td>
                    <td><strong>@c.Name</strong></td>
                    <td>@c.Slug</td>
                    <td>
                        <a href="/Admin/EditCategory/@c.CategoryId" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                        <form asp-action="DeleteCategory" method="post" style="display:inline" onsubmit="return confirm('Xóa danh mục này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.CategoryId" />
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>