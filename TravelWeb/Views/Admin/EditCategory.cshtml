@model TravelWeb.Models.Category
@{
    ViewData["Title"] = "Sửa Danh mục";
    Layout = "_AdminLayout";
}

<div class="data-card">
    <h5><i class="fas fa-edit me-2"></i>Sửa: @Model.Name</h5>
    <form asp-action="EditCategory" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="CategoryId" type="hidden" />

        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">Tên danh mục</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Icon (emoji)</label>
                <input asp-for="Icon" class="form-control" maxlength="5" />
            </div>
            <div class="col-md-12">
                <label class="form-label">Slug</label>
                <input asp-for="Slug" class="form-control" />
            </div>
            <div class="col-md-12">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-12">
                <a href="/Admin/Categories" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn-admin"><i class="fas fa-save me-1"></i> Cập nhật</button>
            </div>
        </div>
    </form>
</div>