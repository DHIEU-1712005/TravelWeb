@model List<TravelWeb.Models.Booking>
@{
    ViewData["Title"] = "Tour của tôi";
}

<div class="page-header">
    <div class="container">
        <h1>🧳 Tour của tôi</h1>
        <p>Lịch sử đặt tour của bạn</p>
    </div>
</div>

<section class="section">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var b in Model)
                {
                    <div class="col-md-12">
                        <div class="form-card">
                            <div class="row align-items-center">
                                <div class="col-md-2 text-center">
                                    <div style="font-size: 60px;">🏖️</div>
                                </div>
                                <div class="col-md-6">
                                    <h5>@b.Tour?.Name</h5>
                                    <p class="mb-1"><i class="fas fa-barcode text-warm me-2"></i>Mã: <strong>@b.BookingCode</strong></p>
                                    <p class="mb-1"><i class="fas fa-calendar text-warm me-2"></i>Khởi hành: @b.DepartureDate.ToString("dd/MM/yyyy")</p>
                                    <p class="mb-1"><i class="fas fa-users text-warm me-2"></i>@b.NumAdults người lớn, @b.NumChildren trẻ em</p>
                                </div>
                                <div class="col-md-4 text-center">
                                    <h4 class="text-warm">@b.FinalAmount.ToString("N0") đ</h4>
                                    @{
                                        var statusColor = b.BookingStatus switch
                                        {
                                            "confirmed" => "success",
                                            "pending" => "warning",
                                            "cancelled" => "danger",
                                            "completed" => "info",
                                            _ => "secondary"
                                        };
                                        var statusText = b.BookingStatus switch
                                        {
                                            "confirmed" => "Đã xác nhận",
                                            "pending" => "Đang chờ",
                                            "cancelled" => "Đã hủy",
                                            "completed" => "Hoàn thành",
                                            _ => b.BookingStatus
                                        };
                                    }
                                    <span class="badge bg-@statusColor mb-2">@statusText</span>
                                    <div>
                                        <a asp-action="Confirm" asp-route-id="@b.BookingId" class="btn btn-outline-warm btn-sm">
                                            <i class="fas fa-eye me-1"></i>Chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div style="font-size: 80px;">🧳</div>
                <h4 class="mt-3">Bạn chưa đặt tour nào</h4>
                <p class="text-muted">Hãy khám phá các tour hấp dẫn của chúng tôi nhé!</p>
                <a asp-controller="Tour" asp-action="Index" class="btn btn-warm mt-3">
                    <i class="fas fa-search me-2"></i>Khám phá ngay
                </a>
            </div>
        }
    </div>
</section>
