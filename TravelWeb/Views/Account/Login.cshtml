@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="section">
    <div class="container">
        <div class="row">
            <div class="col-md-5 mx-auto">
                <div class="form-card">
                    <div class="text-center mb-4">
                        <div style="font-size: 60px;">🔐</div>
                        <h3>Đăng nhập</h3>
                        <p class="text-muted">Chào mừng trở lại! Đăng nhập để tiếp tục</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label"><i class="fas fa-envelope me-2"></i>Email</label>
                            <input type="email" name="email" class="form-control" required placeholder="email@example.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><i class="fas fa-lock me-2"></i>Mật khẩu</label>
                            <input type="password" name="password" class="form-control" required placeholder="Nhập mật khẩu" />
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="remember" />
                                <label class="form-check-label" for="remember">Ghi nhớ</label>
                            </div>
                            <a href="#" class="text-warm">Quên mật khẩu?</a>
                        </div>
                        <button type="submit" class="btn btn-warm w-100">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p>Chưa có tài khoản? <a asp-action="Register" class="text-warm fw-bold">Đăng ký ngay</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
