<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vi Vu Việt Nam</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Top bar -->
    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-phone me-2"></i> Hotline: 1900 1234
                <span class="ms-3"><i class="fas fa-envelope me-2"></i> info@vivuvietnam.vn</span>
            </div>
            <div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="me-3"><i class="fas fa-user me-1"></i> Xin chào, @User.Identity.Name</span>
                    if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="text-white me-3"><i class="fas fa-cog me-1"></i> Admin</a>
                    }
                    <a asp-controller="Booking" asp-action="MyBookings" class="text-white me-3"><i class="fas fa-suitcase me-1"></i> Tour của tôi</a>
                    <a asp-controller="Account" asp-action="Logout" class="text-white"><i class="fas fa-sign-out-alt me-1"></i> Đăng xuất</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="text-white me-3"><i class="fas fa-sign-in-alt me-1"></i> Đăng nhập</a>
                    <a asp-controller="Account" asp-action="Register" class="text-white"><i class="fas fa-user-plus me-1"></i> Đăng ký</a>
                }
            </div>
        </div>
    </div>

    <!-- Header / Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">✈️</span>
                <span class="brand-text">Vi Vu <span class="text-warm">Việt Nam</span></span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Tour" asp-action="Index"><i class="fas fa-map-marked-alt me-1"></i> Tour du lịch</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About"><i class="fas fa-info-circle me-1"></i> Giới thiệu</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact"><i class="fas fa-phone me-1"></i> Liên hệ</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash messages -->
    @if (TempData["Success"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row py-5">
                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">✈️ Vi Vu Việt Nam</h5>
                    <p>Người bạn đồng hành tin cậy trên mọi cung đường. Mang đến cho bạn những trải nghiệm du lịch tuyệt vời và đáng nhớ nhất.</p>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h5 class="footer-title">Khám phá</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Tour" asp-action="Index">Tour du lịch</a></li>
                        <li><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Hỗ trợ</h5>
                    <ul class="footer-links">
                        <li><a href="#">Câu hỏi thường gặp</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Điều khoản sử dụng</a></li>
                        <li><a href="#">Hướng dẫn thanh toán</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Liên hệ</h5>
                    <p><i class="fas fa-map-marker-alt me-2"></i> 123 Nguyễn Huệ, Q.1, TP.HCM</p>
                    <p><i class="fas fa-phone me-2"></i> 1900 1234</p>
                    <p><i class="fas fa-envelope me-2"></i> info@vivuvietnam.vn</p>
                </div>
            </div>
            <div class="footer-bottom text-center py-3">
                <p class="mb-0">© 2026 Vi Vu Việt Nam - Made with <i class="fas fa-heart text-warm"></i> in Vietnam</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
