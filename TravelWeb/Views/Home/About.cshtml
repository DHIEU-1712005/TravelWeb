@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="page-header">
    <div class="container">
        <h1>Về chúng tôi</h1>
        <p>Người bạn đồng hành tin cậy trên mọi cung đường</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="destination-card-img-placeholder" style="height: 400px; border-radius: 20px;">🌏</div>
            </div>
            <div class="col-md-6">
                <h2 class="mb-4">✈️ Vi Vu Việt Nam</h2>
                <p class="lead">Chúng tôi là công ty du lịch hàng đầu Việt Nam với hơn 10 năm kinh nghiệm tổ chức tour trong và ngoài nước.</p>
                <p>Với phương châm "Mang đến trải nghiệm tuyệt vời nhất cho khách hàng", chúng tôi luôn không ngừng nỗ lực để cung cấp những sản phẩm du lịch chất lượng cao với giá cả hợp lý nhất.</p>
                <div class="row mt-4">
                    <div class="col-6">
                        <h3 class="text-warm">10+</h3>
                        <p>Năm kinh nghiệm</p>
                    </div>
                    <div class="col-6">
                        <h3 class="text-warm">100K+</h3>
                        <p>Khách hàng hài lòng</p>
                    </div>
                    <div class="col-6">
                        <h3 class="text-warm">500+</h3>
                        <p>Tour đa dạng</p>
                    </div>
                    <div class="col-6">
                        <h3 class="text-warm">50+</h3>
                        <p>Điểm đến</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section" style="background: white;">
    <div class="container">
        <div class="section-title">
            <h2>🎯 Sứ mệnh & Giá trị</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon"><i class="fas fa-bullseye"></i></div>
                    <h5>Sứ mệnh</h5>
                    <p>Mang đến những trải nghiệm du lịch đáng nhớ, an toàn và chất lượng cho mọi khách hàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon"><i class="fas fa-eye"></i></div>
                    <h5>Tầm nhìn</h5>
                    <p>Trở thành công ty du lịch số 1 Việt Nam về chất lượng dịch vụ và sự hài lòng của khách hàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon"><i class="fas fa-gem"></i></div>
                    <h5>Giá trị cốt lõi</h5>
                    <p>Uy tín - Tận tâm - Chuyên nghiệp - Sáng tạo - Đồng hành cùng khách hàng.</p>
                </div>
            </div>
        </div>
    </div>
</section>
